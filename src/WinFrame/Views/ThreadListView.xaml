<UserControl x:Class="WinFrame.Views.ThreadListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinFrame.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- New Thread Button -->
        <Border Grid.Row="0" Padding="12,8">
            <Button Style="{StaticResource IconButton}"
                    Command="{Binding NewThreadCommand}"
                    HorizontalAlignment="Stretch"
                    Padding="10,8"
                    ToolTip="New Thread">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="New Thread" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Border>

        <!-- Thread List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Style="{StaticResource DarkScrollViewer}">
            <ItemsControl ItemsSource="{Binding Threads}" x:Name="ThreadsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ThreadViewModel}">
                        <Border Margin="6,2" CornerRadius="6" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOnboarding}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PinnedThreadBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SelectedThreadBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.SelectThreadCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Grid Margin="10,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                           Margin="0,0,8,0" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#x1F4AC;"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnboarding}" Value="True">
                                                    <Setter Property="Text" Value="&#x2605;"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Title -->
                                <TextBlock Grid.Column="1" Text="{Binding Title}"
                                           FontSize="13" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOnboarding}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Close button (only non-onboarding) -->
                                <Button Grid.Column="2"
                                        Style="{StaticResource IconButton}"
                                        Command="{Binding DataContext.CloseThreadCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="4" Margin="2,0,0,0"
                                        Visibility="{Binding IsOnboarding, Converter={StaticResource InverseBoolToVis}}"
                                        ToolTip="Close thread">
                                    <TextBlock Text="&#x2715;" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
