<UserControl x:Class="WinFrame.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="420" Margin="40">

            <!-- Logo -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <TextBlock Text="&#x2B21;" FontSize="48" Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="WinFrame" FontSize="36" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="AI-powered coding assistant"
                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <!-- Initial login panel -->
            <StackPanel Visibility="{Binding IsDeviceFlowActive, Converter={StaticResource InverseBoolToVis}}">
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartLoginCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="20,14">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x2714;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Sign in with GitHub" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="Sign in to access GitHub Copilot AI assistance"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- Device flow panel -->
            <StackPanel Visibility="{Binding IsDeviceFlowActive, Converter={StaticResource BoolToVis}}">

                <Border Background="#1A2030" BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Open your browser and go to:"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="github.com/login/device"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Then enter this code:"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6"/>

                        <Border Background="#0D0D0D" CornerRadius="6" Padding="16,10"
                                HorizontalAlignment="Center">
                            <TextBlock Text="{Binding DeviceCode, FallbackValue='XXXX-XXXX'}"
                                       FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="&#x21BB;" FontSize="16" Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusMessage, FallbackValue='Waiting for authorization...'}"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Style="{StaticResource IconButton}"
                        Command="{Binding CancelLoginCommand}"
                        HorizontalAlignment="Center"
                        Padding="12,6">
                    <TextBlock Text="Cancel" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
